# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (.env.example is the committed template, never the rest)
.env*
!.env.example

# vercel
.vercel

# local npm cache (workaround for root-owned global cache)
.npm-cache

# prisma
/prisma/migrations/dev.db
*.db

# uploads (local dev image storage)
/public/uploads

# typescript
*.tsbuildinfo
next-env.d.ts
