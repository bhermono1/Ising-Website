# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/karaoke_dev"

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Generate with: npx auth secret    (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test"
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ──────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Crescendo Karaoke <reservations@yourdomain.com>"

# ── File uploads (Vercel Blob) ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ── Rate limiting (Upstash Redis) — optional, falls back to no-op in dev ─
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
